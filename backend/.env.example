# Banco de dados (preenchido automaticamente pelo Render via DATABASE_URL,
# ou use as variáveis abaixo individualmente para rodar localmente)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=banco1
DB_SCHEMA=integrador
DB_USER=postgres
DB_PASSWORD=postgres
# DATABASE_URL=postgres://user:senha@host:5432/banco

JWT_SECRET=troque-por-um-valor-aleatorio-seguro
JWT_EXPIRES_IN=8h

PORT=3001
NODE_ENV=development

# Chave de API para integração externa (G3/Agenda, G4/Consultas)
# Enviar no header: X-API-Key
PARTNER_API_KEY=troque-por-uma-chave-aleatoria
